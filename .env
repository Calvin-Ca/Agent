# ============================================================
# Smart Weekly Report Agent — Environment Configuration
# Copy to .env and fill in values
# ============================================================
# .env 文件不支持行内注释
# .env 里的 CUDA_VISIBLE_DEVICES 只对 FastAPI 进程生效，Celery worker 是独立进程，需要单独指定

# ---- Models ----
# 后端选择: local | api | ollama
EMBED_BACKEND=api
LLM_BACKEND=api
VLM_ENABLED=false

# ==============================================================
# Embedding 调用方式（三选一，修改 EMBED_BACKEND 切换）
# ==============================================================

# 方式1: 本地加载 (EMBED_BACKEND=local)
# sentence-transformers 直接加载，支持 BGE / m3e / GTE 等
EMBED_MODEL_PATH=models/embeddings/bge-large
EMBED_DEVICE=cuda
EMBED_BATCH_SIZE=32

# 方式2: vLLM 服务器 API (EMBED_BACKEND=api)
# 服务器上用 vLLM --task embed 部署的 embedding 服务
EMBED_API_BASE=http://172.19.3.136:8097/v1
EMBED_MODEL_NAME=/model

# 方式3: Ollama (EMBED_BACKEND=ollama)
OLLAMA_BASE_URL=http://172.19.3.136:11434
OLLAMA_EMBED_MODEL=bge-large

# ==============================================================
# LLM 调用方式（三选一，修改 LLM_BACKEND 切换）
# ==============================================================

# 方式1: 本地加载 (LLM_BACKEND=local)
# 直接用 transformers 加载本地权重，适合 ≤14B 模型单卡部署
LLM_MODEL_PATH=models/llm/qwen3-8b
LLM_DEVICE=cuda
LLM_MAX_TOKENS=2048

# 方式2: vLLM / TGI 服务器 API (LLM_BACKEND=api)
# 服务器上用 vLLM 部署，本地通过 OpenAI 兼容接口调用
LLM_API_BASE=http://172.19.3.136:8099/v1
LLM_API_KEY=

# 方式3: Ollama (LLM_BACKEND=ollama)
# OLLAMA_BASE_URL 与 Embedding 共用，见上方
OLLAMA_LLM_MODEL=qwen3-8b

# ==============================================================
# VLM 调用方式（VLM_ENABLED=true 时生效，用于图片 OCR 增强描述）
# ==============================================================

# 方式1: 本地加载
# 直接用 transformers 加载，支持 Qwen2-VL / LLaVA 等多模态模型
VLM_MODEL_PATH=models/vlm/qwen2-vl-7b
VLM_DEVICE=cuda

# 方式2: vLLM 服务器 API
# 服务器上用 vLLM 部署多模态模型，通过 OpenAI 兼容接口调用
VLM_API_BASE=http://172.19.3.136:8099/v1
VLM_API_KEY=
VLM_MODEL_NAME=qwen2-vl-7b

# 方式3: Ollama
# Ollama 支持部分多模态模型，如 llava / moondream
OLLAMA_VLM_MODEL=llava


# ---- Application ----
APP_NAME=smart-weekly-report
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-64-char-string
API_V1_PREFIX=/api/v1

# ---- MySQL ----
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3367
MYSQL_USER=caic
MYSQL_PASSWORD=caic
MYSQL_DATABASE=caic

# ---- Redis ----
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ---- Milvus ----
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
MILVUS_COLLECTION=doc_embeddings
MILVUS_DIM=1024

# ---- MinIO / Object Storage ----
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=weekly-report
MINIO_SECURE=false

# ---- Celery ----
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2

# ---- JWT ----
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440


