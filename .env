# ============================================================
# Smart Weekly Report Agent — Environment Configuration
# Copy to .env and fill in values
# ============================================================
# .env 文件不支持行内注释
# .env 里的 CUDA_VISIBLE_DEVICES 只对 FastAPI 进程生效，Celery worker 是独立进程，需要单独指定


# ---- Application ----
APP_NAME=smart-weekly-report
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-64-char-string
API_V1_PREFIX=/api/v1

# ---- MySQL ----
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=calvin
MYSQL_PASSWORD=caic
MYSQL_DATABASE=calvin

# ---- Redis ----
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ---- Milvus ----
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19531
MILVUS_COLLECTION=doc_embeddings
MILVUS_DIM=1024

# ---- Models ----
# 模型根目录（项目内，已 gitignore）
MODEL_ROOT=models

# Embedding 模型
EMBED_MODEL_PATH=models/embeddings/bge-m3
EMBED_DEVICE=cuda
EMBED_BATCH_SIZE=32
# local | api | ollama
EMBED_BACKEND=local

# LLM 模型
LLM_MODEL_PATH=models/llm/gemma-4-e2b-it
LLM_DEVICE=cuda
LLM_MAX_TOKENS=2048
# local | api | ollama
LLM_BACKEND=local

# VLM 模型
VLM_MODEL_PATH=models/llm/gemma-4-e2b-it
VLM_ENABLED=true

# API backend (vLLM / TGI)
LLM_API_BASE=http://127.0.0.1:8001/v1
LLM_API_KEY=
EMBED_API_BASE=http://127.0.0.1:8002/v1
EMBED_MODEL_NAME=bge-m3

# Ollama backend
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_LLM_MODEL=qwen2.5:14b
OLLAMA_EMBED_MODEL=bge-m3

# ---- MinIO / Object Storage ----
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=weekly-report
MINIO_SECURE=false

# ---- Celery ----
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2

# ---- JWT ----
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ---- CUDA ----
CUDA_VISIBLE_DEVICES=1
